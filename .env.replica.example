# MiniRaft Replica Configuration
# Copy to .env.replica1 (or .env.replica2, .env.replica3) and update values for your network

# Unique replica identifier
REPLICA_ID=replica1

# Port this replica listens on (typically 5001 for all)
PORT=5001

# Gateway address (where frontend connects)
# For multi-device setup with hostnames:
GATEWAY_URL=http://gateway.local:4000

# All replicas in the cluster (including this one)
# For multi-device setup with hostnames:
ALL_REPLICAS_URLS=http://replica1.local:5001,http://replica2.local:5001,http://replica3.local:5001

# Alternative: using IP addresses
# GATEWAY_URL=http://192.168.1.100:4000
# ALL_REPLICAS_URLS=http://192.168.1.101:5001,http://192.168.1.102:5001,http://192.168.1.103:5001
