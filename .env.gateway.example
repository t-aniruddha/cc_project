# MiniRaft Gateway Configuration
# Copy to .env.gateway and update values for your network

# Port the gateway listens on
PORT=4000

# Comma-separated list of replica URLs
# For multi-device setup with hostnames:
REPLICA_URLS=http://replica1.local:5001,http://replica2.local:5001,http://replica3.local:5001

# Alternative: using IP addresses
# REPLICA_URLS=http://192.168.1.101:5001,http://192.168.1.102:5001,http://192.168.1.103:5001
